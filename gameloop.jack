class gameloop{

    function bool gameWin(Array game_state, int potezi){
        var bool win;
        let win = false;
        //ZA X
        if (
            // vodoravno 1
            ((game_state[0] = 1) & (game_state[1] = 1) & (game_state[2] = 1)) )
        
            {
                do Output.moveCursor(22, 20);
                do Output.printString("Igrac X je pobijedio!");
                do Screen.drawLine(130, 61, 345, 61);
                do Screen.drawLine(130, 62, 345, 62);
                let win = true;
            }
        if (
            // vodoravno 2
            ((game_state[3] = 1) & (game_state[4] = 1) & (game_state[5] = 1)))
        
            {
                do Output.moveCursor(22, 20);
                do Output.printString("Igrac X je pobijedio!");
                do Screen.drawLine(130, 128, 345, 128);
                do Screen.drawLine(130, 129, 345, 129);
                let win = true;
                
            }
        if (
            // vodoravno 3
            ((game_state[6] = 1) & (game_state[7] = 1) & (game_state[8] = 1)))
        
            {
