        if (
            // dijagonala 2
            ((game_state[2] = 1) & (game_state[4] = 1) & (game_state[6] = 1)))

            {
                do Output.moveCursor(22, 20);
                do Output.printString("Igrac X je pobijedio!");
                do Screen.drawLine(349, 36, 130, 223);
                do Screen.drawLine(350, 36, 131, 223);
                do Screen.drawLine(351, 36, 132, 223);
                let win = true;
