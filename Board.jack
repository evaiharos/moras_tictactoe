    function void draw_y(int polje){
        if(polje = 1){
            do Screen.drawCircle(158, 61, 19);

            do Screen.setColor(false);  // false = bijelo (briše)
            do Screen.drawCircle(158, 61, 16);
            do Screen.setColor(true);   // vrati na crno za daljnje crtanje

        }
        if(polje = 2){
            do Screen.drawCircle(238, 61, 19);

            do Screen.setColor(false);  // false = bijelo (briše)
