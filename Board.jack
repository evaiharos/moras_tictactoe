    function void board() {
        // Horizontalne linije (debljina 2 piksela)
        do Screen.drawLine(125, 91, 355, 91);
        do Screen.drawLine(125, 92, 355, 92);
        
        do Screen.drawLine(125, 165, 355, 165);
        do Screen.drawLine(125, 166, 355, 166);
        
        // Vertikalne (debljina 2 piksela)
        do Screen.drawLine(195, 31, 195, 225);
        do Screen.drawLine(196, 31, 196, 225);
        
        do Screen.drawLine(280, 31, 280, 225);
        do Screen.drawLine(281, 31, 281, 225);
        return;
    }
    
    function void drawBoard() {
        var int key;
        let key = 0;
        do Screen.clearScreen();
        

        do Board.board();

        do Output.moveCursor(5, 20);
        do Output.printString("1");
        do Output.moveCursor(5, 29);
        do Output.printString("2");
        do Output.moveCursor(5, 39);
        do Output.printString("3");
        do Output.moveCursor(11, 20);
        do Output.printString("4");
        do Output.moveCursor(11, 29);
        do Output.printString("5");
        do Output.moveCursor(11, 39);
        do Output.printString("6");
        do Output.moveCursor(18, 20);
        do Output.printString("7");
        do Output.moveCursor(18, 29);
        do Output.printString("8");
        do Output.moveCursor(18, 39);
        do Output.printString("9");

        do Output.moveCursor(5, 48);
        do Output.printString("ZAPAMTI:");
        do Output.moveCursor(6, 48);
        do Output.printString("tijekom igranja");
        do Output.moveCursor(7, 48);
        do Output.printString("izaberi polje");
        do Output.moveCursor(8, 48);
        do Output.printString("pritiskom");
        do Output.moveCursor(9, 48);
        do Output.printString("odgovarajuceg");
        do Output.moveCursor(10, 48);
        do Output.printString("broja (1-9)");

        do Output.moveCursor(11, 1);
        do Output.printString("Igrac X pocinje!");
        
        do Output.moveCursor(21, 36);
        do Output.printString("Pritisni Space za nastavak");
        
        
        while (~(Keyboard.keyPressed() = 0)) {
            // Čekaj dok su tipke pritisnute
        }
    
        // Zatim čekaj novi pritisak Space
        while (key = 0) {
            let key = Keyboard.keyPressed();

            if (~(key = 32)) {
                let key = 0;
            }
        }
    
        // Ponovo sačekaj da se tipka otpusti prije povratka
        while (~(Keyboard.keyPressed() = 0)) {
            // cekaj otpuštanje
        }

        return;
    }
